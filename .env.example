APP_NAME=Progressia
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost:8000
# ASSET_URL is used by Storage::disk('public')->url() and asset generators.
# Falls back to APP_URL if not set. Set this to your CDN URL in production
# (e.g. https://cdn.progressia.example.com) to decouple static asset delivery
# from the main app domain.
ASSET_URL=http://localhost:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DAILY_DAYS=14
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# Production: prefer redis (set CACHE_STORE=redis, requires REDIS_HOST/REDIS_PASSWORD)
# Fallback: file (no external dependency)
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@progressia.app"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Broadcasting (Reverb)
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

REVERB_ALLOWED_ORIGINS="${APP_URL}"

# Reverb rate limiting (recommended in production)
REVERB_APP_RATE_LIMITING_ENABLED=true
REVERB_APP_RATE_LIMIT_MAX_ATTEMPTS=60
REVERB_APP_RATE_LIMIT_DECAY_SECONDS=60

# Frontend URL (for CORS)
FRONTEND_URL="${APP_URL}"

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Production overrides:
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://progressia.example.com
# FRONTEND_URL=https://progressia.example.com
# LOG_STACK=daily
# LOG_DAILY_DAYS=30
# LOG_LEVEL=warning
# SESSION_SECURE_COOKIE=true
# CACHE_STORE=redis
# REVERB_SCHEME=https
# REVERB_ALLOWED_ORIGINS="${FRONTEND_URL}"

# Queue worker (run via supervisor in production):
#   command: php artisan queue:work --tries=3 --max-time=3600 --sleep=3
#   user: forge
#   numprocs: 2
#   autostart: true
#   autorestart: true
#   stopwaitsecs: 3600
#   redirect_stderr: true
#   stdout_logfile: /home/forge/progressia.example.com/storage/logs/queue.log

# Reverb server (run via supervisor in production):
#   command: php artisan reverb:start --port=8080 --hostname=0.0.0.0
#   user: forge
#   numprocs: 1
#   autostart: true
#   autorestart: true
#   stopwaitsecs: 3600
#   stdout_logfile: /home/forge/progressia.example.com/storage/logs/reverb.log

# Rate limiting: configured in App\Providers\AppServiceProvider via RateLimiter::for()
# - 'login' : 5 per minute per email+IP
# - 'register' : 3 per minute per IP
# - 'webhooks' : 60 per minute per IP (reserved for future)

# Trusted proxies (Caddy/Nginx reverse proxy):
# Set TRUSTED_PROXIES="*"
# Or comma-separated: TRUSTED_PROXIES="10.0.0.1,10.0.0.2"
